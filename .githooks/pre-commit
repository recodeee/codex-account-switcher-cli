#!/usr/bin/env bash
set -euo pipefail

branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
if [[ -z "$branch" ]]; then
  exit 0
fi

if [[ "${ALLOW_COMMIT_ON_PROTECTED_BRANCH:-0}" == "1" ]]; then
  exit 0
fi

protected_branches_raw="$(git config --get multiagent.protectedBranches || true)"
if [[ -z "$protected_branches_raw" ]]; then
  protected_branches_raw="dev main master"
fi
read -r -a protected_branches <<< "$protected_branches_raw"

is_protected_branch=0
for protected_branch in "${protected_branches[@]}"; do
  if [[ "$branch" == "$protected_branch" ]]; then
    is_protected_branch=1
    break
  fi
done

if [[ "$is_protected_branch" == "1" ]]; then
  git_dir="$(git rev-parse --git-dir)"
  if [[ -f "$git_dir/MERGE_HEAD" ]]; then
    exit 0
  fi

  cat >&2 <<'MSG'
[agent-branch-guard] Direct commits on protected branches are blocked.
Use an agent branch first:
  bash scripts/agent-branch-start.sh "<task-or-plan>" "<agent-name>"
After finishing work:
  bash scripts/agent-branch-finish.sh

Temporary bypass (not recommended):
  ALLOW_COMMIT_ON_PROTECTED_BRANCH=1 git commit ...
MSG
  exit 1
fi

if [[ "$branch" == agent/* ]]; then
  require_sync_before_commit="$(git config --bool --get multiagent.sync.requireBeforeCommit || echo "false")"
  if [[ "$require_sync_before_commit" == "true" ]]; then
    base_branch="$(git config --get multiagent.baseBranch || true)"
    if [[ -z "$base_branch" ]]; then
      base_branch="dev"
    fi

    max_behind="$(git config --int --get multiagent.sync.maxBehindCommits || echo "0")"
    if [[ -z "$max_behind" ]]; then
      max_behind="0"
    fi

    if git fetch origin "$base_branch" --quiet 2>/dev/null; then
      behind_count="$(git rev-list --count "HEAD..origin/${base_branch}" 2>/dev/null || echo "0")"
      if [[ "$behind_count" =~ ^[0-9]+$ ]] && [[ "$max_behind" =~ ^-?[0-9]+$ ]] && (( behind_count > max_behind )); then
        cat >&2 <<MSG
[agent-branch-guard] Agent branch is behind origin/${base_branch} by ${behind_count} commit(s),
which exceeds the allowed threshold (${max_behind}).
Sync your branch before committing:
  musafety sync --base ${base_branch}
or:
  git merge --no-edit origin/${base_branch}
MSG
        exit 1
      fi
    else
      cat >&2 <<MSG
[agent-branch-guard] Could not fetch origin/${base_branch} for behind-check.
Fix remote connectivity or temporarily disable with:
  git config multiagent.sync.requireBeforeCommit false
MSG
      exit 1
    fi
  fi

  if [[ "${MUSAFETY_AUTOCLAIM_STAGED_LOCKS:-1}" == "1" ]]; then
    while IFS= read -r staged_file; do
      [[ -z "$staged_file" ]] && continue
      [[ "$staged_file" == ".omx/state/agent-file-locks.json" ]] && continue
      python3 scripts/agent-file-locks.py claim --branch "$branch" "$staged_file" >/dev/null 2>&1 || true
    done < <(git diff --cached --name-only --diff-filter=ACMRDTUXB)
  fi

  if ! python3 scripts/agent-file-locks.py validate --branch "$branch" --staged; then
    cat >&2 <<'MSG'
[agent-branch-guard] Agent branch commits require file ownership locks.
Claim files first:
  python3 scripts/agent-file-locks.py claim --branch "$(git rev-parse --abbrev-ref HEAD)" <file...>
MSG
    exit 1
  fi

  if ! python3 scripts/main_rs_lock.py validate --branch "$branch" --staged; then
    cat >&2 <<'MSG'
[agent-branch-guard] main.rs changes require an active main.rs lock owned by this branch.
main.rs is integrator-only (default branch pattern: agent/integrator/...).
Claim lock first from the integrator branch:
  python3 scripts/main_rs_lock.py claim --owner "<agent-name>" --branch "$(git rev-parse --abbrev-ref HEAD)"
MSG
    exit 1
  fi
fi

if command -v pre-commit >/dev/null 2>&1 && [[ -f .pre-commit-config.yaml ]]; then
  pre-commit run --hook-stage pre-commit
fi
